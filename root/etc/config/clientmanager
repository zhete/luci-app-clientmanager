config global 'global'
	option enabled '1'
	option autoblock '0'
	option traffic_monitor '1'
	option data_retention '30'
	option scan_interval '60'
	list blocked ''

config notification 'notification'
	option enabled '0'
	option new_device '1'
	option device_blocked '1'
	option email ''

config limit
	option mac ''
	option download '0'
	option upload '0'
